# ─── EventJelly Frontend — Environment Variables ──────────────────────────────
#
# LOCAL DEVELOPMENT (Vite dev server with proxy)
# Leave VITE_API_URL empty so requests hit the Vite proxy at /api → localhost:3000
# and VITE_SOCKET_URL points directly to the backend WS port.
#
# PRODUCTION / DOCKER
# Set VITE_API_URL to the full backend URL, e.g. http://api.eventjelly.com
# Set VITE_SOCKET_URL to the same host (WebSocket uses the same port as the API)
# ──────────────────────────────────────────────────────────────────────────────

# Base URL for all REST API calls.
# - Leave blank (or /api) during local dev to use the Vite proxy.
# - Set to the full backend origin in production: https://api.eventjelly.com
VITE_API_URL=

# WebSocket server URL.
# - Leave blank during local dev to fall back to http://localhost:3000
# - Set to backend origin in production: https://api.eventjelly.com
VITE_SOCKET_URL=

# App name shown in browser tabs / meta tags (optional)
VITE_APP_NAME=EventJelly
